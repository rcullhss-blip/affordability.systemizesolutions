# Production environment template — values filled by Railway
# Do NOT commit real secrets here.

# Set by Railway Postgres plugin automatically:
# DATABASE_URL=postgresql://...

# Set by Railway Redis plugin automatically:
# REDIS_URL=redis://...

ENVIRONMENT=production
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING

# AWS S3 — for document storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
S3_BUCKET_RAW=systemize-raw-reports
S3_BUCKET_OUTPUTS=systemize-outputs

# Anthropic — for AI wording improvements (optional at launch)
ANTHROPIC_API_KEY=

# Fallback local storage path (used if S3 keys are empty)
LOCAL_STORAGE_PATH=/app/storage
