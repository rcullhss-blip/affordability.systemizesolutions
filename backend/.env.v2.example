# ── V2 sandbox backend env ────────────────────────────────────────────────────
# Copy to .env on the SEPARATE V2 Railway service. Must use its OWN database and
# Redis — never the live V1 instances.

# Separate V2 database + Redis (NOT the live ones)
DATABASE_URL=postgresql://...v2-db...
REDIS_URL=redis://...v2-redis...

SECRET_KEY=change-me-v2

# Storage (a separate bucket/prefix keeps V2 test outputs apart from live)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
S3_BUCKET_RAW=systemize-raw-reports-v2
S3_BUCKET_OUTPUTS=systemize-outputs-v2

ANTHROPIC_API_KEY=
ENVIRONMENT=sandbox

# ── V2 feature flag — THIS is what turns the estimated claim value on ──────────
CLAIM_VALUE_ESTIMATE_ENABLED=true
